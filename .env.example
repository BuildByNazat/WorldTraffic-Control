# WorldTraffic Control — Backend Environment Variables
# Copy this file to backend/.env and uncomment any variables you need.

# ── Aircraft data source ────────────────────────────────────────────────────
# AIRCRAFT_PROVIDER=simulated   # "simulated" (default) | "opensky"
# OPENSKY_USERNAME=             # OpenSky Network username (optional — increases rate limit)
# OPENSKY_PASSWORD=             # OpenSky Network password

# ── Broadcast timing ────────────────────────────────────────────────────────
# BROADCAST_INTERVAL=5.0        # Seconds between WebSocket pushes to clients

# ── Camera ingestion ────────────────────────────────────────────────────────
# CAMERA_FETCH_INTERVAL=60.0    # Seconds between camera reachability checks

# ── Gemini vision analysis (Phase 3) ───────────────────────────────────────
# Obtain a key at: https://aistudio.google.com/app/apikey
# If not set, camera analysis is silently skipped — the app still works.
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Database (Phase 4 — SQLite) ─────────────────────────────────────────────
# The SQLite file is created automatically. Default: backend/data/worldtraffic.db
# Override with an absolute path if needed (e.g. a shared network location).
# DB_PATH=backend/data/worldtraffic.db
