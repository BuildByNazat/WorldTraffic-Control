# WorldTraffic Control backend environment example
#
# Copy to either:
# - backend/.env        (recommended for the provided backend scripts)
# - .env                (project-root fallback)
#
# Required:
# - none for anonymous OpenSky evaluation mode
#
# Optional:
# - OPENSKY_USERNAME / OPENSKY_PASSWORD for authenticated OpenSky evaluation
# - GEMINI_API_KEY to enable camera image analysis

# Deployment mode
# Use development locally and production for public-serving deployments.
APP_ENV=development

# Aviation runtime mode
# demo        = developer-only simulated feed
# evaluation  = use a real evaluation provider such as OpenSky, with simulated fallback
# commercial  = reserve this for a future licensed provider handoff
AVIATION_DATA_MODE=evaluation

# Aviation provider adapter
# opensky          = current primary real-data evaluation path
# simulated        = developer fallback / explicit demo override
# commercial_stub  = placeholder only, for future vendor credential handoff
AVIATION_PROVIDER=opensky

# Legacy fallback is still accepted if AVIATION_PROVIDER is omitted:
# AIRCRAFT_PROVIDER=simulated

# Developer demo override example
# AVIATION_DATA_MODE=demo
# AVIATION_PROVIDER=simulated

# OpenSky evaluation example
# AVIATION_DATA_MODE=evaluation
# AVIATION_PROVIDER=opensky
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=
#
# Notes:
# - leaving both OpenSky fields empty still works for anonymous evaluation
# - set both username and password together when you receive evaluation credentials
# - OpenSky coverage can be sparse or delayed; the app will flag stale tracks and fall back to simulated data if the provider fails

# Future commercial provider handoff example
# AVIATION_DATA_MODE=commercial
# AVIATION_PROVIDER=commercial_stub
# COMMERCIAL_PROVIDER_NAME=
# COMMERCIAL_API_BASE_URL=
# COMMERCIAL_API_KEY=
#
# Notes:
# - do not populate fake secrets here
# - the stub keeps the wiring visible without pretending a vendor is finalized

# Timing
BROADCAST_INTERVAL=5.0
CAMERA_FETCH_INTERVAL=60.0

# Vision
# GEMINI_API_KEY=

# Persistence
DB_PATH=data/worldtraffic.db

# Auth / private beta rollout
# AUTH_SIGNUP_ENABLED controls whether new browser signups are accepted.
# For a serious private beta, disable this and provision invited accounts directly.
AUTH_SIGNUP_ENABLED=true

# Database-backed bearer session token entropy.
# Increase only if you have a specific security requirement; 32 is a practical default.
AUTH_SESSION_TOKEN_BYTES=32

# Public app URL used for deployment-facing status and docs.
# Example: https://traffic.example.com
# PUBLIC_BASE_URL=

# Comma-separated allowed frontend origins for browser access.
# Keep the local defaults or replace with your deployed frontend URL(s).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Frontend deployment note:
# - production should prefer same-origin /api and /ws/live behind a reverse proxy
# - set VITE_API_URL / VITE_WS_URL only if frontend and backend must live on separate origins
