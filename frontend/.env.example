# Frontend environment example
#
# Copy to frontend/.env.local when you need to override the default same-origin
# production behavior.
#
# Required:
# - none if the frontend is served behind the same host/proxy as the backend
#
# Optional:
# - VITE_API_URL for an explicit API origin
# - VITE_WS_URL for an explicit WebSocket URL
# - VITE_DEV_PROXY_TARGET to change the Vite dev proxy backend target

# Explicit backend origin overrides
# VITE_API_URL=http://localhost:8000
# VITE_WS_URL=ws://localhost:8000/ws/live

# Local development proxy target used by vite.config.ts
VITE_DEV_PROXY_TARGET=http://localhost:8000
